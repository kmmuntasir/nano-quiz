# Server Configuration
PORT=3000

# Frontend URL (used for CORS origin)
FRONTEND_URL=http://localhost:5173

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Email domain restriction (optional, e.g., @example.com)
# RESTRICT_DOMAIN=

# JWT secret for signing app tokens
JWT_SECRET=your-jwt-secret-key

# PostgreSQL connection string (Supabase)
SUPABASE_DB_URL=postgresql://user:password@host:port/database

# Event deadline in ISO 8601 format (optional, unset = open indefinitely)
# EVENT_DEADLINE_ISO=2026-12-31T23:59:59Z

# Record per-question view timestamps (optional, default: false)
# TRACK_PER_QUESTION_TIME=false
